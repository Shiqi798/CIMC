{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GD32 OpenOCD Launch (App@0x08008000)",
            "cwd": "${workspaceFolder:vscode eide}",
            "executable": "${workspaceFolder:vscode eide}/build/TASK/TASK.axf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 1000"
            ],
            "gdbPath": "C:/Program Files (x86)/GNU Arm Embedded Toolchain/10 2020-q4-major/bin/arm-none-eabi-gdb.exe",
            "device": "GD32F470VE",
            "interface": "swd",
            "showDevDebugOutput": "none",
            "svdFile": "${workspaceFolder:vscode eide}/.pack/GigaDevice/GD32F4xx_DFP.3.0.3/SVD/GD32F4xx.svd",
            "postLaunchCommands": [
                "monitor reset halt",
                "set *(unsigned int*)0xE000ED08 = 0x08008000",
                "set $sp = *(unsigned int*)0x08008000",
                "set $pc = *(unsigned int*)0x08008004"
            ]
        },
        {
            "name": "GD32 Attach Existing GDB Server :3333",
            "cwd": "${workspaceFolder:vscode eide}",
            "executable": "${workspaceFolder:vscode eide}/build/TASK/TASK.axf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "external",
            "gdbTarget": "localhost:3333",
            "gdbPath": "C:/Program Files (x86)/GNU Arm Embedded Toolchain/10 2020-q4-major/bin/arm-none-eabi-gdb.exe",
            "device": "GD32F470VE",
            "interface": "swd",
            "showDevDebugOutput": "none",
            "postAttachCommands": [
                "monitor halt",
                "set *(unsigned int*)0xE000ED08 = 0x08008000",
                "set $sp = *(unsigned int*)0x08008000",
                "set $pc = *(unsigned int*)0x08008004"
            ]
        },
        {
            "name": "GD32 ST-Link Launch (Fallback)",
            "cwd": "${workspaceFolder:vscode eide}",
            "executable": "${workspaceFolder:vscode eide}/build/TASK/TASK.axf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "stlink",
            "gdbPath": "C:/Program Files (x86)/GNU Arm Embedded Toolchain/10 2020-q4-major/bin/arm-none-eabi-gdb.exe",
            "device": "GD32F470VE",
            "interface": "swd",
            "showDevDebugOutput": "none",
            "svdFile": "${workspaceFolder:vscode eide}/.pack/GigaDevice/GD32F4xx_DFP.3.0.3/SVD/GD32F4xx.svd"
        }
    ]
}